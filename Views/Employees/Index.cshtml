@model IEnumerable<EmployeeCRUD.Models.Employee>

@{
    ViewData["Title"] = "Employees List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Employees List</h1>
    <a asp-action="Create" class="btn btn-primary">Create New Employee</a>
</div>

<table class="table table-striped table-hover border">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Id)</th>
            <th>Name</th> @* Replace with actual property names like model.Name if different *@
            <th>Email</th>
            <th>Department</th>
            <th>Salary</th>
            <th>Address</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@Html.DisplayFor(modelItem => item.Department)</td>
                <td>@Html.DisplayFor(modelItem => item.Salary)</td>
                <td>@Html.DisplayFor(modelItem => item.Address)</td>
                <td class="text-end">
                    <div class="btn-group" role="group">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>

                        <!-- Delete Form mapped to DeleteConfirmed action via [ActionName("Delete")] -->
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this employee?');" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>